# Streamlit Community Cloud 배포 시 이 파일을 참고해
# Streamlit Cloud > 앱 설정 > Secrets 에 아래 내용을 입력하세요.
# 로컬 PC에서는 이 파일을 secrets.toml 로 복사해 API 키를 입력하면 됩니다.
# (secrets.toml 은 .gitignore 에 포함되어 있어 GitHub에 올라가지 않습니다.)

GEMINI_API_KEY = "여기에_Gemini_API_키_입력"

# Claude API 폴백이 필요한 경우 (선택)
# ANTHROPIC_API_KEY = "여기에_Claude_API_키_입력"
